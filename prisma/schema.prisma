generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  language      String    @default("fr")
  timezone      String    @default("Europe/Paris")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  tasks            Task[]
  habits           Habit[]
  calendarAccounts CalendarAccount[]
  dailyRecaps      DailyRecap[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CalendarAccount {
  id           String           @id @default(cuid())
  userId       String
  provider     String
  name         String
  color        String           @default("#4F46E5")
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  calendarId   String?
  isDefault    Boolean          @default(false)
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks        Task[]
  subCalendars SubCalendar[]
}

model SubCalendar {
  id                String   @id @default(cuid())
  calendarAccountId String
  externalId        String
  name              String
  color             String   @default("#4F46E5")
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  calendarAccount CalendarAccount @relation(fields: [calendarAccountId], references: [id], onDelete: Cascade)

  @@unique([calendarAccountId, externalId])
}

model Task {
  id                String     @id @default(cuid())
  userId            String
  calendarAccountId String?
  title             String
  description       String?
  importance        Int        @default(5)
  urgency           Int        @default(5)
  priority          Int        @default(0)
  status            String     @default("PENDING")
  estimatedMinutes  Int?
  actualMinutes     Int?
  scheduledStart    DateTime?
  scheduledEnd      DateTime?
  deadline          DateTime?
  completedAt       DateTime?
  isRecurring       Boolean    @default(false)
  parentTaskId      String?
  calendarEventId   String?
  tags              String?
  notes             String?
  aiSuggested       Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  calendarAccount CalendarAccount? @relation(fields: [calendarAccountId], references: [id])
  parentTask      Task?            @relation("SubTasks", fields: [parentTaskId], references: [id])
  subTasks        Task[]           @relation("SubTasks")
}

model Habit {
  id              String   @id @default(cuid())
  userId          String
  title           String
  description     String?
  color           String   @default("#10B981")
  icon            String?
  frequency       String   @default("DAILY")
  targetDays      String?
  scheduledTime   String?
  durationMinutes Int?
  calendarEventId String?
  isActive        Boolean  @default(true)
  streak          Int      @default(0)
  longestStreak   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  completions HabitCompletion[]
}

model HabitCompletion {
  id          String   @id @default(cuid())
  habitId     String
  completedAt DateTime @default(now())
  notes       String?

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
}

model DailyRecap {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  summary     String
  tasksTotal  Int      @default(0)
  tasksDone   Int      @default(0)
  tasksMissed Int      @default(0)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
